// ================================================================
// CHARTS — Water extent using original script logic (feature.byFeature)
// ================================================================

// Pre-normalise jrcDatasetFull so every image has exactly one band
// named 'waterClass', safely handling any edge-case 0-band images.
// JRC YearlyHistory band is already named 'waterClass'; recentAnnual
// images are also named 'waterClass' — so rename([0]) is safe here
// only after confirming bands exist via ee.Algorithms.If.
var jrcNormalised = jrcDatasetFull.map(function(img) {
  var safe = ee.Image(ee.Algorithms.If(
    img.bandNames().size().gt(0),
    img.rename('waterClass').byte(),   // rename all → takes first band safely
    ee.Image.constant(0).rename('waterClass').byte()
  ));
  return safe
    .updateMask(lakeMask)
    .set('system:time_start', img.get('system:time_start'));
});

// Replicate the original script's logic exactly:
// For each annual image, count class-2 (seasonal) AND class-3 (permanent)
// water pixels multiplied by pixel area, then reduce to a single area value.
// Uses scale: 30 to match JRC native resolution, consistent with original.
var yearlyWaterArea = jrcNormalised.map(function(img) {
  var year = ee.Date(img.get('system:time_start')).get('year');

  // Seasonal water (class 2) area
  var seasonalArea = img.eq(2)
    .multiply(ee.Image.pixelArea())
    .reduceRegion({
      reducer: ee.Reducer.sum(),
      geometry: roi,
      scale: 30,
      maxPixels: 1e13,
      bestEffort: true
    }).get('waterClass');

  // Permanent water (class 3) area
  var permanentArea = img.eq(3)
    .multiply(ee.Image.pixelArea())
    .reduceRegion({
      reducer: ee.Reducer.sum(),
      geometry: roi,
      scale: 30,
      maxPixels: 1e13,
      bestEffort: true
    }).get('waterClass');

  // Total water area in sq km (m² / 1e6)
  var totalArea = ee.Number(seasonalArea).add(ee.Number(permanentArea))
                    .divide(1e6);

  return ee.Feature(null, {
    'year':          year,
    'seasonalArea':  ee.Number(seasonalArea).divide(1e6),
    'permanentArea': ee.Number(permanentArea).divide(1e6),
    'totalArea':     totalArea
  });
});

var waterExtentChart = ui.Chart.feature.byFeature({
  features: yearlyWaterArea,
  xProperty: 'year',
  yProperties: ['seasonalArea', 'permanentArea', 'totalArea']
}).setOptions({
