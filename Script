    1: {color: '#1E90FF', lineDashStyle: [4,2], lineWidth: 1, pointSize: 2},  // permanent
    2: {color: '#08306b', lineWidth: 2,          pointSize: 3}                // total
  },
  legend: {position: 'bottom'}
});

// WST chart — Landsat annual mean, scale 100 m
